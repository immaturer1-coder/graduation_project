<%# Rails 7 / Devise / Tailwind CSS 完全統合版ログインフォーム %>
<script src="https://cdn.tailwindcss.com"></script>

<style>
  /* スクロールを禁止し、1画面に収めるためのスタイル */
  html, body {
    height: 100%;
    overflow: hidden;
    position: fixed;
    width: 100%;
    margin: 0;
    padding: 0;
    touch-action: none;
  }
</style>

<div class="fixed inset-0 bg-slate-950 text-slate-100 font-sans flex items-center justify-center p-4 overflow-hidden select-none">
  <div class="w-full max-w-md flex flex-col h-full max-h-[750px]">
    
    <!-- ロゴセクション -->
    <div class="text-center my-auto">
      <h1 class="text-4xl font-black tracking-tighter bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent mb-1">
        FocusFlow
      </h1>
      <p class="text-slate-400 text-[10px] tracking-widest uppercase font-medium">Deep focus, once again.</p>
    </div>

    <!-- フォームカード -->
    <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 shadow-2xl flex-shrink-0">
      <h2 class="text-base font-bold mb-4 text-center uppercase tracking-[0.2em] text-slate-300">Log in</h2>
      
      <%# Devise標準の form_for を使用しつつ、Turboを無効化 (data: { turbo: false }) して確実にHTML送信を行います %>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4", data: { turbo: false } }) do |f| %>
        
        <%# エラーメッセージ（ログイン失敗時）の表示エリア %>
        <% if flash[:alert] %>
          <div class="bg-red-500/10 border border-red-500/50 text-red-500 text-[11px] font-bold p-3 rounded-xl text-center animate-pulse">
            <%= flash[:alert] %>
          </div>
        <% end %>

        <div class="space-y-1.5">
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Email</label>
          <div class="relative">
            <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
            </div>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full bg-slate-950 border border-slate-800 rounded-xl py-2.5 pl-10 pr-4 focus:outline-none focus:border-indigo-500 transition-all text-sm text-white placeholder:text-slate-700", placeholder: "Email", required: true %>
          </div>
        </div>

        <div class="space-y-1.5">
          <div class="flex justify-between items-center ml-1">
            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest">Password</label>
            <%- if devise_mapping.recoverable? %>
              <%= link_to "Forgot?", new_password_path(resource_name), class: "text-[9px] text-indigo-400 hover:text-indigo-300 font-bold uppercase tracking-tighter" %>
            <% end %>
          </div>
          <div class="relative">
            <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <%= f.password_field :password, autocomplete: "current-password", class: "w-full bg-slate-950 border border-slate-800 rounded-xl py-2.5 pl-10 pr-4 focus:outline-none focus:border-indigo-500 transition-all text-sm text-white placeholder:text-slate-700", placeholder: "Password", required: true %>
          </div>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2 px-1">
            <%= f.check_box :remember_me, class: "w-3.5 h-3.5 rounded border-slate-800 bg-slate-950 text-indigo-600 focus:ring-0 focus:ring-offset-0" %>
            <%= f.label :remember_me, "Remember me", class: "text-[11px] text-slate-500 font-medium cursor-pointer" %>
          </div>
        <% end %>

        <div class="pt-2">
          <%= f.submit "Log in", class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-black py-3 rounded-xl transition-all shadow-lg shadow-indigo-500/20 cursor-pointer active:scale-[0.98] border-none text-sm" %>
        </div>
      <% end %>

      <div class="relative my-6 text-center">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-slate-800"></div>
        </div>
        <span class="relative px-3 bg-slate-900 text-[9px] text-slate-600 uppercase tracking-[0.3em] font-black italic">or</span>
      </div>

      <div class="text-center">
        <%- if devise_mapping.registerable? %>
          <%= link_to "Create new account", new_registration_path(resource_name), class: "text-[11px] text-slate-500 hover:text-indigo-400 transition-colors font-bold" %>
        <% end %>
      </div>
    </div>

    <!-- フッターリンク -->
    <div class="my-auto text-center">
      <p class="text-[11px] text-slate-600 font-bold">
        Don't have an account? 
        <%= link_to "Sign up", new_registration_path(resource_name), class: "text-indigo-400 hover:underline ml-1" %>
      </p>
    </div>
  </div>
</div>